# 服务端配置（前缀不带 VITE_）
SERVER_PORT=4000

# 知乎开放接口
ZHIHU_APP_KEY=your_app_key
ZHIHU_APP_SECRET=your_app_secret
ZHIHU_OPENAPI_BASE_URL=https://openapi.zhihu.com
# 调试时如需走本地 fixture 不打真实接口，设为 1；正常开发请留空
ZHIHU_USE_FIXTURE=

# AI 服务接入
# 可选值：mock | kimi
AI_PROVIDER=mock
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
# 推荐模型：kimi-k2.6 / kimi-k2-0905-preview / moonshot-v1-32k
KIMI_MODEL=kimi-k2.6
KIMI_TEMPERATURE=0.7

# 文件缓存目录（服务端本地）
CACHE_DIR=./.cache/yyan-ai
CDN_BASE_URL=

# 前端开发代理（前端只用这一项，其它前缀不带 VITE_ 的变量不会暴露给浏览器）
VITE_API_BASE=/api
