{
  "name": "yyan-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig ./tsconfig.json ./src/index.ts",
    "build": "tsc -p ./tsconfig.build.json --outDir dist && tsc-alias -p ./tsconfig.build.json && node scripts/fix-esm.mjs",
    "start": "node dist/src/index.js",
    "typecheck": "tsc -p ./tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "tsc-alias": "^1.8.17",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
